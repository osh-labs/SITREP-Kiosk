# Field SITREP Board — environment variables
# Copy to .env and fill in. Never commit .env.

# NWS api.weather.gov needs no key, only a descriptive User-Agent.
NWS_USER_AGENT="UnitedConsulting-FieldSITREP/1.0 (contact: you@example.com)"

# 511GA developer key (free; register at 511ga.org). Rate limit: 10 calls / 60 s.
GA511_API_KEY=

# EPA AirNow API key (free; register at airnowapi.org). Rate limit: 500 req/hr/service.
AIRNOW_API_KEY=

# Anthropic API key for briefing generation. Model: claude-haiku-4-5.
ANTHROPIC_API_KEY=

# Local server port for the kiosk to point at.
SITREP_PORT=8080
