[Desktop Entry]
# =============================================================================
# sitrep-kiosk.desktop — autostart entry for the Field SITREP Board kiosk
#
# Install location: ~/.config/autostart/sitrep-kiosk.desktop
# (where ~ is the kiosk user's home directory)
#
# WHY DESKTOP AUTOSTART (not systemd --user for the kiosk):
#   Chromium in kiosk mode requires an active X11/Wayland display session.
#   The desktop autostart mechanism fires after the display server and
#   desktop session manager are up, making it the most reliable way to
#   ensure DISPLAY is set correctly.  A systemd --user unit can also work
#   (see the README for the alternative), but requires graphical-session.target
#   to be properly reached, which varies across display managers
#   (LightDM, GDM, SDDM).  The .desktop approach is simpler and more
#   portable across Debian/Ubuntu kiosk setups.
#
# PLACEHOLDER: replace __INSTALL_DIR__ with the actual repo root path,
# e.g. /opt/sitrep.  The install.sh script does this automatically.
# =============================================================================
[Desktop Entry]
Type=Application
Name=SITREP Kiosk
Comment=Field SITREP Board — Chromium kiosk launcher
Exec=bash __INSTALL_DIR__/deploy/kiosk.sh
X-GNOME-Autostart-enabled=true
# Do not show in application menus
NoDisplay=true
# Run even if there is no network yet (the kiosk script handles waiting)
X-GNOME-Autostart-Delay=5
